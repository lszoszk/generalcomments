_docs_internal/hf-build/

# Local Claude Code session config — not deployment-relevant.
.claude/

# CCPR Centre fetched datasets — reproducible from
# _docs_internal/ccprcentre/fetch_ccprcentre_decisions.py (script IS
# tracked); the JSON dumps are big (10 MB+) and rebuildable, so don't
# bloat history with them.
_docs_internal/ccprcentre/*.json

# v2 build staging (parallel target experiment) — generated artefacts.
docs_v2/

# Re-extraction working dir: fetched OHCHR source PDFs/DOCs are
# rebuildable from each doc's `link` URL via apply_reextraction.py.
# The script + extracted .txt files ARE tracked (auditable + small).
_docs_internal/reextract/pdfs/
_docs_internal/reextract/__pycache__/

# SP heading extraction working dir: fetched UN documents.un.org
# PDFs (75 MB across 173 docs). Rebuildable from each doc's symbol
# via extract_sp_sections.py. The scripts + sections.json (the
# canonical output) ARE tracked; PDFs are not.
_docs_internal/sp-headings/pdfs/
_docs_internal/sp-headings/texts/
_docs_internal/sp-headings/__pycache__/

# SP footnote extraction working dir: fetched documents.un.org docx
# files (37 MB across 167 docs — native docx + .doc/.wpc fallbacks).
# Rebuildable via extract_sp_footnotes.py. The scripts + footnotes.json
# (the canonical extraction output) ARE tracked; docx/.doc files are not.
_docs_internal/footnotes/docx/
_docs_internal/footnotes/__pycache__/

# CESCR jurisprudence ingestion: fetched documents.un.org docx files
# (~9 MB across 147 decisions). Rebuildable via extract_cescr.py.
# Scripts + cescr.json + case_list.json (canonical outputs) ARE
# tracked; the docx cache is not.
_docs_internal/cescr/docx/
_docs_internal/cescr/__pycache__/
